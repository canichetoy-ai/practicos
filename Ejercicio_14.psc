Algoritmo Ejercicio_14
	Definir hotel, comida, dias, pd, cheque Como entero
	Escribir "Ingrese los dias que se quedara la persona: "
	Leer dias
	Escribir "Ingrese el gasto diario del hotel: "
	Leer hotel
	Escribir "Ingrese el gasto por comida: "
	Leer comida
	
	pd= 100000
	
	cheque = (hotel + comida + pd) * dias
	
	Escribir "El total del chequq deberia ser de:$ ", cheque
	
FinAlgoritmo
