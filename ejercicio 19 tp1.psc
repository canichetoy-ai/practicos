Algoritmo sin_titulo
	Definir edad_ańos Como Entero
	Definir meses, semanas, dias, horas Como entero
	Escribir "Escriba su edad en ańos:"
	Leer edad_ańos
	meses <- edad_ańos * 12
	semanas <- edad_ańos * 52
	dias <- edad_ańos * 365
	horas <- dias * 24
	Escribir "Tiempo vivido Aproximadamente:"
	Escribir "Meses:" , meses
	Escribir "Semanas: " , semanas
	Escribir "Dias: " , dias
	Escribir "Horas: " , horas
FinAlgoritmo
